#!/usr/bin/with-contenv bashio
# shellcheck shell=bash

CERT_DIR=/data/letsencrypt
WORK_DIR=/data/dehydrated
API_URL="https://api.ayodo.ru/v1"

TOKEN=$(bashio::config 'token')
LOCAL_PORT=$(bashio::config 'local_port')
EMAIL=$(bashio::config 'email')
EXTERNAL_DOMAIN=$(bashio::config 'external_domain')

# Define key parameters
KEY_TYPE="rsa"
KEY_LENGTH="4096"
KEY_NAME="ayodo_rsa"
KEY_COMMENT=$EMAIL
KEY_DIR="/config/.ssh"
KEY_PATH="$KEY_DIR/$KEY_NAME"

if [[ -f "$KEY_PATH" && -f "$KEY_PATH.pub" ]]; then
    echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] SSH keys already exists"
else
  echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] Generating SSH key pair..."
  if [[ -d $KEY_DIR ]]; then
      rm -rf $KEY_DIR
  fi
  # Generate the SSH key pair
  mkdir $KEY_DIR
  ssh-keygen -t "$KEY_TYPE" -b "$KEY_LENGTH" -f "$KEY_PATH" -C "$KEY_COMMENT" -N ""
  if [ $? -eq 0 ]; then
      echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] SSH key pair generated successfully:"
  else
      echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] Error generating SSH key pair."
      exit 1
  fi
fi

PUBLIC_KEY=$(<"$KEY_PATH.pub")

if [[ "${EXTERNAL_DOMAIN}" == "null" ]]; then
  EXTERNAL_DOMAIN=""
fi
EXTERNAL_DOMAIN="$(echo "${EXTERNAL_DOMAIN}" | tr '[:upper:]' '[:lower:]' | xargs)"

echo " ŌÆČ Request to Ayodo API..."
if ! Response=$(curl -X POST\
    -L "$API_URL/connect/home" \
    -H "Content-Type: application/json" \
    -H "Accept: application/json" \
    -d "{\"token\":\"${TOKEN}\", \"email\":\"${EMAIL}\", \"public_key\":\"${PUBLIC_KEY}\", \"synonym\":\"${EXTERNAL_DOMAIN}\"}");
then
    bashio::log.fatal "Something went wrong contacting the API. Response: {$Response}"
    return "${__BASHIO_EXIT_NOK}"
fi

if (bashio::jq.exists "${Response}" ".code") && (bashio::jq "${Response}" ".code" != 200); then
    bashio::log.fatal "Something went wrong contacting the API. Response: {$Response}"
    return "${__BASHIO_EXIT_NOK}"
fi

# Get data from Response
USER=$(bashio::jq "${Response}" ".tunnel_user")
HOST=$(bashio::jq "${Response}" ".tunnel_host")
TUNNEL_PORT=$(bashio::jq "${Response}" ".tunnel_port")
SSH_PORT=$(bashio::jq "${Response}" ".ssh_port")
DOMAIN=$(bashio::jq "${Response}" ".domain")
SYNONYM=$(bashio::jq "${Response}" ".synonym")

if [[ "$USER" == "null" || "$HOST" == "null" || "$TUNNEL_PORT" == "null" || "$SSH_PORT" == "null" || "$DOMAIN" == "null" ]] ; then
    bashio::log.fatal "Something went wrong contacting the API. Response: {$Response}"
    return "${__BASHIO_EXIT_NOK}"
fi
echo " ŌÆČ Got data from API."

DOMAIN="$(echo "${DOMAIN}" | tr '[:upper:]' '[:lower:]' | xargs)"
if [[ "${SYNONYM}" == "null" ]]; then
  SYNONYM=""
fi
SYNONYM="$(echo "${SYNONYM}" | tr '[:upper:]' '[:lower:]' | xargs)"
if [[ -z "${SYNONYM}" ]]; then
  SYNONYM="${EXTERNAL_DOMAIN}"
fi

# Init folder structs
mkdir -p "${CERT_DIR}"
mkdir -p "${WORK_DIR}"
if [[ -n "${SYNONYM}" && "${SYNONYM}" != "${DOMAIN}" ]]; then
  echo "${DOMAIN} ${SYNONYM}" > "${WORK_DIR}/domains.txt"
  echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] External domain synonym enabled: ${SYNONYM}"
else
  echo "${DOMAIN}" > "${WORK_DIR}/domains.txt"
fi

if bashio::config.true "accept_terms"; then
  # Clean up possible stale lock file
  if [ -e "${WORK_DIR}/lock" ]; then
      rm -f "${WORK_DIR}/lock"
      bashio::log.warning " ŌÆČ Reset dehydrated lock file"
  fi
  # shellcheck disable=SC1091
  . /root/renew_certs.sh
  renew_certs "${CERT_DIR}" "${WORK_DIR}"

  echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] Add cron task for renew"
  echo "0 3 * * * run-parts /etc/periodic/daily >> /data/last_run.log 2>&1" > /etc/crontabs/root
fi

echo " ŌÆČ Create tunnel..."

autossh -M 20000 -fN -p "${SSH_PORT}" -R "${TUNNEL_PORT}":"localhost":"${LOCAL_PORT}" "${USER}"@"${HOST}" -i $KEY_PATH \
 -o "ServerAliveInterval=10" \
 -o "ServerAliveCountMax=3" \
 -o "PubkeyAuthentication=yes" \
 -o "PasswordAuthentication=no" \
 -o "StrictHostKeyChecking=no"

echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] Tunnel successfully created."
echo " ŌÆČ [$(date +'%d-%m-%Y %H:%M:%S')] Start UI"

echo " ŌÆČ ąŻčüčéą░ąĮąŠą▓ą║ą░ čāčüą┐ąĄčłąĮąŠ ąĘą░ą▓ąĄčĆčłąĄąĮą░!"
echo " ŌÆČ ą¤ąŠčüą╗ąĄ ąĮą░čüčéčĆąŠą╣ą║ąĖ ą║ąŠąĮčäąĖą│čāčĆą░čåąĖąĖ Home Assistant ą▒čāą┤ąĄčé ą┤ąŠčüčéčāą┐ąĄąĮ ą┐ąŠ ą░ą┤čĆąĄčüčā:"
echo " ŌÆČ https://${DOMAIN}"
if [[ -n "${SYNONYM}" && "${SYNONYM}" != "${DOMAIN}" ]]; then
  echo " ŌÆČ ąóą░ą║ąČąĄ čćąĄčĆąĄąĘ ą▓ąĮąĄčłąĮąĖą╣ ą┤ąŠą╝ąĄąĮ: https://${SYNONYM}"
fi

python3 /root/webui.py
